<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Galaxia de Amor 3D de Alta Calidad</title>
    <style>
        body {
            margin: 0;
            overflow: hidden;
            background-color: #000;
            font-family: 'Arial', sans-serif;
        }
        #canvas-container {
            width: 100vw;
            height: 100vh;
            position: absolute;
            top: 0;
            left: 0;
            z-index: 1;
        }
    </style>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>
</head>
<body>

    <div id="canvas-container"></div>

    <script>
        // --- CONFIGURACIÓN ESCENA 3D ---
        const container = document.getElementById('canvas-container');
        const scene = new THREE.Scene();
        
        // Cámara
        const camera = new THREE.PerspectiveCamera(60, window.innerWidth / window.innerHeight, 0.1, 1000);
        camera.position.z = 4;

        // Renderizador con máxima calidad y antialiasing activado
        const renderer = new THREE.WebGLRenderer({ antialias: true, powerPreference: "high-performance" });
        renderer.setSize(window.innerWidth, window.innerHeight);
        // Forzamos el pixel ratio nativo del dispositivo para máxima nitidez (HD)
        renderer.setPixelRatio(window.devicePixelRatio);
        container.appendChild(renderer.domElement);

        // --- CREACIÓN DE LA GALAXIA (PARTÍCULAS) ---
        const count = 25000; // Más partículas para mayor densidad y calidad visual
        const positions = new Float32Array(count * 3);
        const colors = new Float32Array(count * 3);

        const colorDentro = new THREE.Color('#ff4a75'); // Rosa brillante
        const colorFuera = new THREE.Color('#1a052e');  // Morado cósmico profundo

        for (let i = 0; i < count; i++) {
            const i3 = i * 3;

            const radio = Math.random() * 5;
            const espiralRamas = 3; 
            const anguloEspiral = ((i % espiralRamas) / espiralRamas) * Math.PI * 2;
            const anguloGiro = radio * 1.5;

            const randomX = (Math.pow(Math.random(), 3) * (Math.random() < 0.5 ? 1 : -1) * 0.25) * radio;
            const randomY = (Math.pow(Math.random(), 3) * (Math.random() < 0.5 ? 1 : -1) * 0.25) * radio;
            const randomZ = (Math.pow(Math.random(), 3) * (Math.random() < 0.5 ? 1 : -1) * 0.25) * radio;

            positions[i3]     = Math.cos(anguloEspiral + anguloGiro) * radio + randomX;
            positions[i3 + 1] = randomY;
            positions[i3 + 2] = Math.sin(anguloEspiral + anguloGiro) * radio + randomZ;

            const colorMezclado = colorDentro.clone();
            colorMezclado.lerp(colorFuera, radio / 5);

            colors[i3]     = colorMezclado.r;
            colors[i3 + 1] = colorMezclado.g;
            colors[i3 + 2] = colorMezclado.b;
        }

        const geometry = new THREE.BufferGeometry();
        geometry.setAttribute('position', new THREE.BufferAttribute(positions, 3));
        geometry.setAttribute('color', new THREE.BufferAttribute(colors, 3));

        // Material estilizado para las estrellas
        const material = new THREE.PointsMaterial({
            size: 0.02,
            sizeAttenuation: true,
            depthWrite: false,
            blending: THREE.AdditiveBlending,
            vertexColors: true
        });

        const galaxia = new THREE.Points(geometry, material);
        scene.add(galaxia);
        galaxia.rotation.x = 0.5;

        // --- PALABRAS FLOTANTES LIMPIAS (SIN CUADROS Y EN ALTA RESOLUCIÓN) ---
        const flotantes = [];
        const textos = ["Te amo", "wiss", "Mi Vida", "feliz cumple", "mi reina", "I love you", "Te Quiero", "My Love", "Me encantas"];
        
        for(let i = 0; i < 20; i++) {
            // Aumentamos el tamaño del canvas interno para que las letras no se pixelen (HD)
            const canvasText = document.createElement('canvas');
            const ctx = canvasText.getContext('2d');
            canvasText.width = 512;
            canvasText.height = 256;

            // Dejamos el fondo completamente transparente (sin rectángulos ni bordes)
            ctx.clearRect(0, 0, 512, 256);
            
            // Estilo del texto con un sutil brillo rosa
            ctx.shadowColor = "#ff4a75";
            ctx.shadowBlur = 15;
            ctx.fillStyle = "#ffffff";
            ctx.font = "Bold 54px Arial";
            ctx.textAlign = "center";
            ctx.textBaseline = "middle";
            ctx.fillText(textos[i % textos.length], 256, 128);

            const textura = new THREE.CanvasTexture(canvasText);
            // Filtros para mejorar la definición visual de la textura
            textura.minFilter = THREE.LinearFilter;
            
            const matPlano = new THREE.MeshBasicMaterial({ 
                map: textura, 
                transparent: true, 
                side: THREE.DoubleSide,
                depthWrite: false
            });
            
            const geoPlano = new THREE.PlaneGeometry(0.8, 0.4);
            const malla = new THREE.Mesh(geoPlano, matPlano);

            // Distribución tridimensional
            malla.position.x = (Math.random() - 0.5) * 5;
            malla.position.y = (Math.random() - 0.5) * 3;
            malla.position.z = (Math.random() - 0.5) * 4;
            
            scene.add(malla);
            flotantes.push(malla);
        }

        // --- INTERACCIÓN ---
        let mouseX = 0;
        let mouseY = 0;
        let targetX = 0;
        let targetY = 0;

        window.addEventListener('mousemove', (event) => {
            mouseX = (event.clientX / window.innerWidth) - 0.5;
            mouseY = (event.clientY / window.innerHeight) - 0.5;
        });

        window.addEventListener('touchmove', (event) => {
            if(event.touches.length > 0) {
                mouseX = (event.touches[0].clientX / window.innerWidth) - 0.5;
                mouseY = (event.touches[0].clientY / window.innerHeight) - 0.5;
            }
        });

        // --- BUCLE DE ANIMACIÓN ---
        const clock = new THREE.Clock();

        const animate = () => {
            const elapsedTime = clock.getElapsedTime();

            // Rotación suave de la galaxia
            galaxia.rotation.y = elapsedTime * 0.03;

            // Movimiento fluido de cámara basado en la interacción
            targetX = mouseX * 1.5;
            targetY = -mouseY * 1.5;
            camera.position.x += (targetX - camera.position.x) * 0.05;
            camera.position.y += (targetY - camera.position.y) * 0.05;
            camera.lookAt(scene.position);

            // Flotación independiente de cada palabra mirando al frente
            flotantes.forEach((objeto, index) => {
                objeto.position.y += Math.sin(elapsedTime * 0.8 + index) * 0.0015;
                objeto.rotation.copy(camera.rotation); 
            });

            renderer.render(scene, camera);
            requestAnimationFrame(animate);
        };

        animate();

        // Soporte para cambios de tamaño de pantalla
        window.addEventListener('resize', () => {
            camera.aspect = window.innerWidth / window.innerHeight;
            camera.updateProjectionMatrix();
            renderer.setSize(window.innerWidth, window.innerHeight);
            renderer.setPixelRatio(window.devicePixelRatio);
        });
    </script>
</body>
</html>
